APP_NAME=TeamMindHub Backend
HOST=0.0.0.0
PORT=8000
RATE_LIMIT_PER_MINUTE=120
MAIN_ORCHESTRATOR=qwen_orchestrator
AVAILABLE_AGENTS=qwen_orchestrator,local_llama,deepseek_researcher
VECTOR_STORE_BACKEND=auto
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
CHROMA_COLLECTION_NAME=teammindhub_chunks
CHROMA_TIMEOUT_SECONDS=5.0
RAGFLOW_ENABLED=false
RAGFLOW_BASE_URL=http://ragflow:9380
RAGFLOW_API_KEY=
RAGFLOW_DATASET_NAME=teammindhub_deep_parse
RAGFLOW_CHUNK_METHOD=naive
RAGFLOW_CLEANUP_DOCUMENTS=true
MINERU_ENABLED=false
MINERU_COMMAND=mineru
MINERU_METHOD=auto
MINERU_BACKEND=pipeline
MINERU_MODEL_SOURCE=huggingface
MINERU_LANGUAGE=ch
MINERU_TIMEOUT_SECONDS=300.0
DOCLING_ENABLED=true
DOCLING_COMMAND=docling
DOCLING_TIMEOUT_SECONDS=120.0
LLAMAINDEX_ENABLED=true
LANGGRAPH_ENABLED=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_TIMEOUT_SECONDS=30.0
GITHUB_API_BASE=https://api.github.com
INSTALLER_CLONE_MODE=clone
